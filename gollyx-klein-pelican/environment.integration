#!/bin/bash

export GOLLYX_KLEIN_PELICAN_HOME="${HOME}/golly/gollyx-klein-pelican"
export GOLLYX_STAGE="integration"

# These are read by the pelican.conf file and exposed to the pelican theme
export GOLLYX_TLD="golly456.life"
export GOLLYX_BASE_UI="https://klein.integration.${GOLLYX_TLD}"
export GOLLYX_BASE_API="https://cloud.klein.${GOLLYX_TLD}"
export GOLLYX_MAPS_API="https://maps.${GOLLYX_TLD}"
