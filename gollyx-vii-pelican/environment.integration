#!/bin/bash

export GOLLYX_PELICAN_HOME="~/golly/pelican/gollyx-vii-pelican"
export GOLLYX_STAGE="integration"

# These read by the pelican.conf file and exposed to the pelican theme
export GOLLYX_TLD="golly456.life"
export GOLLYX_BASE_UI="https://vii.integration.${GOLLYX_TLD}"
export GOLLYX_BASE_API="https://cloud.vii.${GOLLYX_TLD}"
export GOLLYX_MAPS_API="https://maps.${GOLLYX_TLD}"
